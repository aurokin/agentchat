{
    "name": "agentchat-web",
    "version": "0.2.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack --hostname 0.0.0.0 --port 4040",
        "build": "next build --turbopack",
        "build:webpack": "next build --webpack",
        "start": "next start",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "test": "bun test",
        "test:confidence": "bun test src/components/chat/__tests__/conversation-runtime-controller.test.ts src/components/chat/__tests__/conversation-runtime-display.test.ts src/components/chat/__tests__/conversation-runtime-helpers.test.ts src/components/chat/__tests__/conversation-runtime-sync.test.ts src/components/chat/__tests__/message-list.test.ts src/contexts/__tests__/agent-helpers.test.ts src/contexts/__tests__/chat-helpers.test.ts src/contexts/__tests__/runtime-helpers.test.ts src/contexts/__tests__/settings-helpers.test.ts src/lib/__tests__/agentchat-server.test.ts src/lib/__tests__/agentchat-socket.test.ts src/lib/__tests__/errors.test.ts src/lib/__tests__/server-issues.test.ts src/lib/__tests__/storage.test.ts src/lib/workspace/__tests__/config.test.ts",
        "health": "bun run format:check && bun run typecheck && bun run lint && bun test"
    },
    "dependencies": {
        "@convex-dev/auth": "^0.0.90",
        "clsx": "^2.1.1",
        "convex": "^1.31.7",
        "date-fns": "^4.1.0",
        "highlight.js": "^11.11.1",
        "lucide-react": "^0.562.0",
        "next": "^16.1.6",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-markdown": "^10.1.0",
        "rehype-highlight": "^7.0.2",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^2.6.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^22.19.7",
        "@types/react": "~19.2.10",
        "@types/react-dom": "~19.2.3",
        "eslint": "^9.39.2",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3"
    }
}
