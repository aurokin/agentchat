# Agentchat (Web) Environment Variables
#
# Agentchat can run in local-only mode with no env vars.
# To enable the Convex-backed workspace, set NEXT_PUBLIC_CONVEX_URL.

# Convex (optional)
# NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# Agentchat backend server (required for provider/model metadata and chat runtime)
# NEXT_PUBLIC_AGENTCHAT_SERVER_URL=http://localhost:8787
