# RouterChat (Web) Environment Variables
#
# RouterChat can run in local-only mode with no env vars.
# To enable cloud sync, set NEXT_PUBLIC_CONVEX_URL.

# Tip: when hosting on Railway, set these as Railway service variables
# instead of committing an `apps/web/.env.local` file.

# Convex (optional)
# NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# RevenueCat (optional)
# Used to build the web purchase link; userId is appended as a path segment.
# REVENUECAT_WEB_PURCHASE_URL=https://pay.rev.cat/<...>

# Legacy alias (prefer REVENUECAT_WEB_PURCHASE_URL)
# NEXT_PUBLIC_REVENUECAT_WEB_PURCHASE_URL=https://pay.rev.cat/<...>

# PostHog analytics (optional)
# Enable analytics only when explicitly set to true.
# NEXT_PUBLIC_ANALYTICS_ENABLED=false
# Optional override for analytics environment tagging when sharing one PostHog project.
# Allowed values: dev | preview | prod (aliases: local->dev, staging->preview, production->prod)
# NEXT_PUBLIC_ANALYTICS_ENV=dev
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Security / debugging (optional)
# Set to force a canonical host redirect (e.g. routerchat.chat -> www.routerchat.chat).
# CANONICAL_HOST=www.routerchat.chat
#
# Set to "true" to disable CSP headers in Next middleware.
# Do not enable this in production.
# DISABLE_CSP=true
