{
    "expo": {
        "name": "Agentchat",
        "slug": "agentchat",
        "scheme": "agentchat",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "experiments": {
            "reactCompiler": true
        },
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.agentchat.app",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "com.agentchat.app"
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "owner": "aurokins-organization",
        "plugins": [
            "expo-router",
            "expo-secure-store",
            "./plugins/withAndroidShareIntent",
            "expo-web-browser"
        ],
        "extra": {
            "router": {},
            "eas": {
                "projectId": "46c85cff-e7c6-443a-aa93-d9fd89440c0d"
            }
        }
    }
}
