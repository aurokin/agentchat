{
    "expo": {
        "name": "RouterChat",
        "slug": "routerchat",
        "scheme": "routerchat",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "experiments": {
            "reactCompiler": true
        },
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.routerchat.app",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "com.routerchat.app"
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "extra": {
            "eas": {
                "projectId": "48d2ca6b-f5c6-4d6b-afe2-dd560e22f0f7"
            }
        },
        "owner": "aurokins-organization",
        "plugins": [
            "expo-router",
            "expo-secure-store",
            "expo-sqlite",
            "./plugins/withAndroidShareIntent"
        ]
    }
}
