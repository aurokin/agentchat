# Agentchat (Mobile) Environment Variables
#
# Agentchat can run in local-only mode with no env vars.
# To enable cloud sync and sign-in, set EXPO_PUBLIC_CONVEX_URL.
#
# Local dev: create `apps/mobile/.env` from this template.

# Convex (optional)
# EXPO_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# Agentchat server (required for model catalog and runtime access)
# EXPO_PUBLIC_AGENTCHAT_SERVER_URL=http://localhost:8787

# Optional / reserved
# Only needed for client-side Google OAuth flows. The current Convex-hosted
# Google sign-in does not require this value.
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
