                            "label": "Medium",
                            "enabled": true
                        },
                        {
                            "id": "high",
                            "label": "High",
                            "enabled": true
                        },
                        {
                            "id": "xhigh",
                            "label": "X-High",
                            "enabled": true
                        }
                    ]
                },
                {
                    "id": "gpt-5.3-codex-spark",
                    "label": "GPT-5.3 Codex Spark",
                    "enabled": true,
                    "supportsReasoning": true,
                    "variants": [
                        {
                            "id": "low",
                            "label": "Low",
                            "enabled": true
                        },
                        {
                            "id": "medium",
