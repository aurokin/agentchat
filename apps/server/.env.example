# Shared secret used to mint backend session tokens in Convex and verify them in apps/server.
# Use the same value in the Convex deployment environment and in apps/server/.env.local.
BACKEND_TOKEN_SECRET=replace-me

# Convex site URL used for trusted runtime persistence HTTP ingress from apps/server.
# Example: https://<deployment>.convex.site
AGENTCHAT_CONVEX_SITE_URL=https://example.convex.site

# Shared secret used by apps/server when posting runtime events into Convex HTTP ingress.
# Use the same value in the Convex deployment environment and in apps/server/.env.local.
RUNTIME_INGRESS_SECRET=replace-me
