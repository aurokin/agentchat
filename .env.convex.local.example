# Convex runtime env vars (Local Development)
#
# Create a gitignored copy at repo root:
#   .env.convex.local
#
# Apply via:
#   bun run convex:env
#
# Note: CONVEX_DEPLOYMENT is used as the target for the CLI, but is NOT set as a runtime env var.

CONVEX_DEPLOYMENT=dev:<your-dev-deployment-name>

# Access mode for this Convex workspace.
# - google: require Google sign-in through Convex Auth
# - disabled: skip external auth and use the default workspace user
AGENTCHAT_AUTH_MODE=google

# Used by Convex Auth to validate redirects back to the app domain.
# apps/web runs on port 4040 in this repo.
SITE_URL=http://localhost:4040

# Google OAuth (only required when AGENTCHAT_AUTH_MODE=google)
AUTH_GOOGLE_ID=...
AUTH_GOOGLE_SECRET=...

# Optional overrides for the default workspace user when AGENTCHAT_AUTH_MODE=disabled.
# AGENTCHAT_DEFAULT_USER_EMAIL=default@local.agentchat
# AGENTCHAT_DEFAULT_USER_NAME=Default User
# AGENTCHAT_DEFAULT_USER_SUBJECT=agentchat-default-user

# Generate and keep these stable for your local Convex instance:
#   bun run convex:gen-secrets
# JWKS=...
# JWT_PRIVATE_KEY=...
# ENCRYPTION_KEY=...
