{
    "name": "routerchat",
    "version": "0.2.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "cd apps/web && bun run dev",
        "build": "cd apps/web && bun run build",
        "start": "cd apps/web && bun run start",
        "format": "prettier --write \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"packages/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "format:check": "prettier --check \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"packages/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "lint": "bun --cwd apps/web run lint && bun --cwd apps/mobile run lint && bun --cwd packages/shared run lint",
        "lint:web": "bun --cwd apps/web run lint",
        "lint:mobile": "bun --cwd apps/mobile run lint",
        "lint:shared": "bun --cwd packages/shared run lint",
        "test": "bun --cwd apps/web run test && bun --cwd apps/mobile run test && bun --cwd packages/shared run test",
        "test:web": "bun --cwd apps/web run test",
        "test:mobile": "bun --cwd apps/mobile run test",
        "test:shared": "bun --cwd packages/shared run test",
        "typecheck": "bun --cwd apps/web run typecheck && bun --cwd apps/mobile run typecheck && bun --cwd packages/shared run typecheck",
        "typecheck:web": "bun --cwd apps/web run typecheck",
        "typecheck:mobile": "bun --cwd apps/mobile run typecheck",
        "typecheck:shared": "bun --cwd packages/shared run typecheck",
        "health": "bun --cwd apps/web run health && bun --cwd apps/mobile run health && bun --cwd packages/shared run health",
        "health:web": "bun --cwd apps/web run health",
        "health:mobile": "bun --cwd apps/mobile run health",
        "health:shared": "bun --cwd packages/shared run health",
        "prepare": "husky"
    },
    "devDependencies": {
        "@fsouza/prettierd": "^0.26.2",
        "@types/bun": "latest",
        "husky": "^9.1.7",
        "prettier": "^3.8.1"
    },
    "prettier": {
        "tabWidth": 4,
        "useTabs": false
    },
    "dependencies": {
        "expo-router": "^6.0.22",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-screens": "~4.16.0",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.3.5"
    }
}
