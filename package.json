{
    "name": "routerchat",
    "version": "0.2.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "cd apps/web && bun run dev",
        "build": "cd apps/web && bun run build",
        "start": "cd apps/web && bun run start",
        "format": "prettier --write \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"packages/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "format:check": "prettier --check \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"packages/**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "health": "cd apps/web && bun health",
        "prepare": "husky"
    },
    "devDependencies": {
        "@fsouza/prettierd": "^0.26.2",
        "@types/bun": "latest",
        "husky": "^9.1.7",
        "prettier": "^3.8.1"
    },
    "prettier": {
        "tabWidth": 4,
        "useTabs": false
    },
    "dependencies": {
        "tailwind-merge": "^3.4.0",
        "zod": "^4.3.5"
    }
}
