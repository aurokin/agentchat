{
  "name": "router-chat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npx next dev --turbopack --hostname 0.0.0.0 --port 4040",
    "build": "cd apps/web && npx next build",
    "typecheck": "cd apps/web && npx tsc --noEmit",
    "test": "cd apps/web && npx next lint"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
